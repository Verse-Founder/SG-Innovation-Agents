# === SEA-LION LLM ===
SEALION_API_KEY=your_sealion_api_key_here
SEALION_BASE_URL=https://api.sea-lion.ai/v1

# === Database ===
# 开发模式默认用 SQLite，生产用 MySQL
DB_URL=sqlite+aiosqlite:///./task_agent.db
# DB_URL=mysql+aiomysql://user:password@localhost:3306/task_agent

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === App ===
ENV=development
LOG_LEVEL=INFO
