# 模板样例：请将此文件重命名为 .env，并填入你真实的 Key
# 注意：千万不要把真实的 .env 提交到 git 上！

# 大模型 API Key (Sea-Lion)
SEA_LION_API_KEY="sk-1234567890abcdef"

# 谷歌 Gemini Vision API Key (如果接入了 Vision Agent 需要配置你的本地 env)
GEMINI_API_KEY="AIzaSy..."

# 数据库链接 (本地测试可以用 sqlite，线上如 PostgreSQL 则为 postgresql://user:pass@host/dbname)
DATABASE_URL="sqlite:///./task_publish.db"

# Redis 链接缓存 Advisor (本地测试为 localhost)
REDIS_URL="redis://localhost:6379/0"
